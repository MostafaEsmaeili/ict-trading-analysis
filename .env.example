# ICT Trading Desk — local environment template.
# Copy this to `.env` (gitignored) and fill in your OANDA practice token. The launch recipe sources
# `.env` so the Host picks these up as standard .NET env-var config overrides (Ict__Section__Key).
# NEVER commit `.env` — it holds the credential. Only this `.env.example` (no secret) is committed.
# PAPER/READ-ONLY ONLY: the OANDA feed is a read-only candle GET feed against the PRACTICE host.

# ---- OANDA credential (the secret) — practice account token ----
# Get it from your OANDA fxPractice account: Manage API Access -> Generate. Practice only.
Ict__MarketData__Oanda__Token=your-oanda-practice-token-here

# ---- Postgres (local dev) ---- (quoted: the value contains ';', which `source` would otherwise split)
ConnectionStrings__PaperTrading="Host=localhost;Port=55432;Database=icttrader;Username=icttrader;Password=icttrader_dev"

# ---- Live feed: OANDA, all 14 catalog instruments x 7 granularities (read-only practice host) ----
Ict__MarketData__Provider=Oanda
Ict__MarketData__Oanda__LiveStreaming=true
Ict__MarketData__Oanda__Instruments__0=EUR_USD
Ict__MarketData__Oanda__Instruments__1=GBP_USD
Ict__MarketData__Oanda__Instruments__2=USD_JPY
Ict__MarketData__Oanda__Instruments__3=AUD_USD
Ict__MarketData__Oanda__Instruments__4=USD_CHF
Ict__MarketData__Oanda__Instruments__5=USD_CAD
Ict__MarketData__Oanda__Instruments__6=NZD_USD
Ict__MarketData__Oanda__Instruments__7=EUR_GBP
Ict__MarketData__Oanda__Instruments__8=EUR_JPY
Ict__MarketData__Oanda__Instruments__9=GBP_JPY
Ict__MarketData__Oanda__Instruments__10=NAS100_USD
Ict__MarketData__Oanda__Instruments__11=SPX500_USD
Ict__MarketData__Oanda__Instruments__12=US30_USD
Ict__MarketData__Oanda__Instruments__13=XAU_USD
# OANDA allowlist tokens (use D, not D1 — the parser maps D->D1). M1/M5/M15/H4 are scanned; M30/H1/D enrich the chart only.
Ict__MarketData__Oanda__Granularities__0=M1
Ict__MarketData__Oanda__Granularities__1=M5
Ict__MarketData__Oanda__Granularities__2=M15
Ict__MarketData__Oanda__Granularities__3=M30
Ict__MarketData__Oanda__Granularities__4=H1
Ict__MarketData__Oanda__Granularities__5=H4
Ict__MarketData__Oanda__Granularities__6=D
Ict__MarketData__Oanda__MaxConcurrentFetchesPerPoll=6
Ict__MarketData__Oanda__HistoryCount=1000
Ict__MarketData__Oanda__PollSeconds=60

# ---- Candle persistence (time-range chart) ----
Ict__MarketData__Persistence__Enabled=true

# ---- Scanning: validated styles only (Intraday=M5, Swing=M15). Add Scalp/Position to scan M1/H4 too. ----
Ict__Scanning__ActiveStyles__0=Intraday
Ict__Scanning__ActiveStyles__1=Swing

# ---- Paper-trading: Auto opens every confirmed setup (no Take). Set Manual for the Take workflow. ----
Ict__PaperTrading__DefaultEntryMode=Auto

# ---- CSV datasets for backtest/optimizer (NOT the live feed) ----
Ict__Backtest__DataDirectory=./data

# ---- Host URL ----
ASPNETCORE_URLS=http://localhost:5080
ASPNETCORE_ENVIRONMENT=Production
