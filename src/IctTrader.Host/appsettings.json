{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Ict": {
    "DefensiveMode": {
      "LiveTradingEnabled": false
    },
    "Time": {
      "ReferenceTimeZone": "America/New_York",
      "DisplayTimeZone": "America/New_York"
    },
    "MarketData": {
      "Provider": "Replay",
      "Replay": {
        "Enabled": false,
        "FixturePath": ""
      }
      // To scan the NASDAQ-100 index live, select the OANDA provider and add "NAS100_USD" to its Instruments list
      // (it normalises to "NAS100USD"). No symbol allow-list blocks it — the per-(symbol,style) scanner registry
      // creates an Index-class scanner automatically once NAS100USD candles arrive (see Ict:Instruments below).
    },
    "Scanning": {
      "ActiveKillzones": [ "LondonOpen", "NewYorkOpen" ],
      "ActiveStyles": [ "Intraday" ],
      // ICT "Silver Bullet" macro overlay (OPT-IN, default OFF → byte-identical). When Enabled, the KillzoneEntry gate
      // is NARROWED to the macro window(s): a setup confirms only inside BOTH an active killzone AND a macro. It adds NO
      // confluence weight (Σ=9.75 untouched) and never opens a disabled killzone (AND, not OR). PROVENANCE: the named
      // "Silver Bullet" is NOT in the 2022 Mentorship (Primer/community canon) — every window here is flagged as such.
      // Default macro (empty list) = the canonical 10:00–11:00 NY AM Silver Bullet; add 03:00–04:00 / 14:00–15:00 to hunt
      // the other community macros. Best on the NQ/ES indices (narrows IndexAm 08:30–11:00 to the macro, e.g. 10:00–10:40
      // after the 10:40 last-entry cutoff). For FX the 10–11 macro needs "LondonClose" in ActiveKillzones (10–11 is the
      // FX LondonClose window). Per-instrument toggling is also available via Ict:Instruments:Overrides + the Settings page.
      "SilverBullet": {
        "Enabled": false,
        "MacroWindows": [
          // { "Start": "10:00", "End": "11:00" }   // configured list REPLACES the default; omit for the 10–11 default
        ]
      }
    },
    // Economic-calendar feed (§2.5.8). When Enabled, a background loader fills the shared event store from the chosen
    // source so the §2.5.2 FOMC/NFP no-trade gate actually fires (CalendarGateDetector withholds CalendarClear on a
    // blacked-out day). Disabled by default → the gate stays fail-open (no day blocked). Provider: "Config" serves the
    // operator-supplied Events below (offline, deterministic — FOMC/NFP schedules publish a year ahead); "Fmp" fetches
    // the Financial Modeling Prep economic calendar over HTTP (read-only GET; Fmp.ApiKey via env/secret, NEVER committed).
    // RefreshHours/LookbackDays/LookaheadDays are INVENTED operational defaults (tune to your FOMC/NFP cadence); the
    // loader window anchors to NY "today", so a HISTORICAL backtest needs a wider LookbackDays to cover its period.
    "Calendar": {
      "Enabled": false,
      "Provider": "Config",
      "RefreshHours": 12,
      "LookbackDays": 7,
      "LookaheadDays": 45,
      "Events": [
        // { "Date": "2024-01-31", "Type": "Fomc" }, { "Date": "2024-02-02", "Type": "Nfp" }  // Type: Fomc | Nfp | Cpi | Other
      ],
      "Fmp": {
        "BaseUrl": "https://financialmodelingprep.com"
        // "ApiKey": "<from env Ict__Calendar__Fmp__ApiKey — never commit>"
      }
    },
    // Per-instrument settings (§2.5.7). The "Overrides" sub-section IS BOUND (InstrumentOverridesOptions) and overlays
    // operator/tuned per-symbol values ON TOP of the pure-domain InstrumentCatalog (config wins where set). The
    // headline knob is MinRequiredConditions — the per-pair k-of-n relaxation; any per-instrument scalar (spread,
    // min-stop, …) can be set here too. FX majors are omitted = strict all-required (the default). A backtest/optimizer
    // run can still override per run; this block is only the LIVE default.
    "Instruments": {
      "Overrides": {
        // BAKED TUNING RESULT (full-history k-of-n sweep, OANDA 2018→2026, ~597k M5 candles / 46 trades — a robust
        // sample): NAS100 trades best at a 6-of-8 k-of-n relaxation. Apples-to-apples on the FULL history, MinRequired=6
        // beats BOTH strict-8 (PF 1.62) AND the prior drop-FvgPresent 7-subset (also PF 1.62): k=6 → 46 trades, 37% win,
        // +0.40R, PF 1.87, +$617 (~1.9 setups/wk — MORE trades AND better quality). DisplacementMss + the latched
        // conditions still gate, so k can't fall into garbage (the sweep saturates at 6). EURUSD/GBPUSD are omitted
        // (strict all-8 — full history confirms EURUSD M15 strict PF 2.20, +0.32R, 62% win, 16 trades; a 2-yr window had
        // SUGGESTED relaxing them but that was a small-sample FLUKE — strict wins on the robust sample, so they stay
        // strict). Re-run the sweep (sweep_full.py / the optimizer) to retune.
        "NAS100USD": {
          "MinRequiredConditions": 6
        },
        // BAKED TUNING RESULT — RE-VALIDATED on the FULL OANDA history 2018→2026 (~632k M5 candles / 54 trades): USD/JPY
        // (one of the four USD majors Michael Huddleston names) KEEPS the drop-FvgPresent 7-subset below. On the robust
        // sample this subset = strict-8 = PF 1.48, +0.24R, 24% win, +$246 (positive). Relaxing further to a 6-of-8 count
        // HURTS it (PF 1.14), so it stays at the 7-subset, NOT k=6 (unlike NAS100). The earlier "PF 2.40" was a shorter
        // 2023→2026 window; PF 1.48 is the honest full-history figure. DisplacementMss stays required (the FSM lock).
        "USDJPY": {
          "RequiredConditions": [ "BiasAligned", "KillzoneEntry", "LiquiditySweep", "DisplacementMss", "PremiumDiscountHalf", "DrawTargetRrMet", "CalendarClear" ]
        }
        // GBPUSD reverted to STRICT (override removed): a full-history retune (this session) shows GBPUSD is weak in
        // every config — M15 strict == the prior drop-{Sweep,FVG} bake == PF 1.18, net loss (74 trades 2018→2026). The
        // earlier "PF 4.44" was an overfit 13-trade 2023→2026 subperiod, not reproducible — so the global strict §2.5
        // model is the honest default for it. AUDUSD (PF 0.60), XAUUSD + SPX500/ES (too few setups) are likewise left
        // strict/unbaked. EURUSD stays strict (M15 PF 1.97 — our best). Re-run the optimizer subset search to retune.
      },
      // DOCUMENTATION ONLY (the leading underscore marks it NOT bound). The per-instrument-class GEOMETRY (point
      // sizing, point-based costs, the FX-vs-index killzone schedule, the TIME-10 macro reference) is resolved by the
      // pure-domain InstrumentCatalog per symbol; it is surfaced here so every invented/derived index number is
      // operator-visible (ICT is SILENT on every numeric index threshold). Editing it has no runtime effect.
      "_NAS100USD_docs": {
        "_class": "Index",
        "_symbolSpec": { "PipSize_points": 1.0, "TickSize": 0.1, "Digits": 1 },           // DERIVED (1 pip = 1 handle); TickSize is the OANDA CFD tick (ICT NQ futures = 0.25)
        "_contractSpec": { "ValuePerPoint_usdPerUnit": 1.0, "LotStep_units": 1, "MinLot_units": 1 }, // CONVENTION (OANDA CFD), NOT the FX 10/pip + 0.01-lot
        "_overrides": {
          "MinStopDistance_points": 10,        // INVENTED — noise floor; echoes the FX 10-pip floor as points, not derived from it
          "StopBuffer_points": 2,              // RULE derived (§2.5.5 "1–2 ticks"); MAGNITUDE INVENTED (2 points is noise-widened)
          "SweptLevelExclusion_points": 2,     // INVENTED — no ICT number; FX 1.5 too tight for NAS100 equal levels
          "FvgMinGap_points": 0,               // DERIVED choice — 0 so the self-scaling ATR gate carries the quality floor
          "FvgStackProximity_points": 10,      // INVENTED — no ICT number; FX 5 too tight for NAS100 stacked gaps
          "EqualLevelTolerance_points": 2,     // INVENTED — no ICT number; FX 1.5 too tight for NAS100 equal H/L
          "CloseProximityTolerance_points": 2, // INVENTED — already flagged; only live under UseCloseProximityEntry
          "SpreadBase_points": 1.0,            // CONVENTION — OANDA NAS100 CFD ~1.0 point during the active AM killzone
          "Commission_usdPerUnit": 0,          // CONVENTION — OANDA NAS100 CFD is commission-free
          "UseMacroOpenReference": true        // TIME-10 (CONTESTED ~80%) resolution — index AM opens 08:30, dual Judas ref (FX stays off)
        }
      }
    },
    // Risk policy (§2.4/§2.5.5). Only the DAILY GUARD is surfaced here; the base risk %, loss-ladder, win-cycle, and
    // portfolio cap bind from their RiskOptions defaults (1% base, 1%→0.5%→0.25% ladder, ~5% cap) unless overridden.
    "Risk": {
      // The §2.4/§2.5.5 circuit-breaker (Ep41 revenge/loser's-cycle, Ep37 "stop pushing buttons", Ep18 "walk away"):
      // HALT new entries for the rest of the NY trading day after a run of losses OR once the day's realized loss hits a
      // cap. It only WITHHOLDS paper entries (no order path — guardrail-clean), never touches already-open/armed trades,
      // and resets at 00:00 NY. DISABLED by default so existing backtests stay byte-identical; RECOMMENDED-ON for live /
      // optimized runs (canonical ICT discipline, the enforcement half of the loss-ladder). The numeric thresholds are
      // INVENTED/community-flagged (not 2022-Mentorship-verbatim): N=3 = the 1%→0.5%→0.25% ladder exhausted; 2.0% ≈ the
      // disciplined-ladder loss (the disaster path reaches ~10%). Set 2 (conservative) / 3 and 2.0–3.0 to taste.
      "DailyGuard": {
        "Enabled": false,
        "ConsecutiveLossHaltThreshold": 3,
        "DailyLossCapPercent": 2.0,
        "ResetAtNyDayRollover": true
      }
    },
    "Killzones": {
      "InstrumentClass": "Fx",
      "NoTradeLunchNy": { "Start": "12:00", "End": "13:00" },
      "Windows": {
        "Asian": { "Start": "19:00", "End": "00:00" },
        "LondonOpen": { "Start": "02:00", "End": "05:00" },
        "NewYorkOpen": { "Start": "07:00", "End": "10:00" },
        "LondonClose": { "Start": "10:00", "End": "11:00" }
      }
    }
  }
}
