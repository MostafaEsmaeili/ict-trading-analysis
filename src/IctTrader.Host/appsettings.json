{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Ict": {
    "DefensiveMode": {
      "LiveTradingEnabled": false
    },
    "Time": {
      "ReferenceTimeZone": "America/New_York",
      "DisplayTimeZone": "America/New_York"
    },
    "MarketData": {
      "Provider": "Replay",
      "Replay": {
        "Enabled": false,
        "FixturePath": ""
      }
      // To scan the NASDAQ-100 index live, select the OANDA provider and add "NAS100_USD" to its Instruments list
      // (it normalises to "NAS100USD"). No symbol allow-list blocks it — the per-(symbol,style) scanner registry
      // creates an Index-class scanner automatically once NAS100USD candles arrive (see Ict:Instruments below).
    },
    "Scanning": {
      "ActiveKillzones": [ "LondonOpen", "NewYorkOpen" ],
      "ActiveStyles": [ "Intraday" ]
    },
    // Per-instrument settings (§2.5.7). The "Overrides" sub-section IS BOUND (InstrumentOverridesOptions) and overlays
    // operator/tuned per-symbol values ON TOP of the pure-domain InstrumentCatalog (config wins where set). The
    // headline knob is MinRequiredConditions — the per-pair k-of-n relaxation; any per-instrument scalar (spread,
    // min-stop, …) can be set here too. FX majors are omitted = strict all-required (the default). A backtest/optimizer
    // run can still override per run; this block is only the LIVE default.
    "Instruments": {
      "Overrides": {
        // BAKED TUNING RESULT: over the fetched OANDA history the NAS100 index made money only with a RELAXED gate —
        // M5 at 6-of-8 confluences scored PF 1.78 (+6.3%) vs the strict all-8 PF 0.70 (losing). So the index scans +
        // sizes at 6-of-8 by DEFAULT (it still needs the weighted score ≥ the alert floor). EURUSD/GBPUSD are omitted
        // (= strict null) because strict was their best (EURUSD M15 PF 1.97). Re-run the optimizer to retune.
        "NAS100USD": { "MinRequiredConditions": 6 }
      },
      // DOCUMENTATION ONLY (the leading underscore marks it NOT bound). The per-instrument-class GEOMETRY (point
      // sizing, point-based costs, the FX-vs-index killzone schedule, the TIME-10 macro reference) is resolved by the
      // pure-domain InstrumentCatalog per symbol; it is surfaced here so every invented/derived index number is
      // operator-visible (ICT is SILENT on every numeric index threshold). Editing it has no runtime effect.
      "_NAS100USD_docs": {
        "_class": "Index",
        "_symbolSpec": { "PipSize_points": 1.0, "TickSize": 0.1, "Digits": 1 },           // DERIVED (1 pip = 1 handle); TickSize is the OANDA CFD tick (ICT NQ futures = 0.25)
        "_contractSpec": { "ValuePerPoint_usdPerUnit": 1.0, "LotStep_units": 1, "MinLot_units": 1 }, // CONVENTION (OANDA CFD), NOT the FX 10/pip + 0.01-lot
        "_overrides": {
          "MinStopDistance_points": 10,        // INVENTED — noise floor; echoes the FX 10-pip floor as points, not derived from it
          "StopBuffer_points": 2,              // RULE derived (§2.5.5 "1–2 ticks"); MAGNITUDE INVENTED (2 points is noise-widened)
          "SweptLevelExclusion_points": 2,     // INVENTED — no ICT number; FX 1.5 too tight for NAS100 equal levels
          "FvgMinGap_points": 0,               // DERIVED choice — 0 so the self-scaling ATR gate carries the quality floor
          "FvgStackProximity_points": 10,      // INVENTED — no ICT number; FX 5 too tight for NAS100 stacked gaps
          "EqualLevelTolerance_points": 2,     // INVENTED — no ICT number; FX 1.5 too tight for NAS100 equal H/L
          "CloseProximityTolerance_points": 2, // INVENTED — already flagged; only live under UseCloseProximityEntry
          "SpreadBase_points": 1.0,            // CONVENTION — OANDA NAS100 CFD ~1.0 point during the active AM killzone
          "Commission_usdPerUnit": 0,          // CONVENTION — OANDA NAS100 CFD is commission-free
          "UseMacroOpenReference": true        // TIME-10 (CONTESTED ~80%) resolution — index AM opens 08:30, dual Judas ref (FX stays off)
        }
      }
    },
    "Killzones": {
      "InstrumentClass": "Fx",
      "NoTradeLunchNy": { "Start": "12:00", "End": "13:00" },
      "Windows": {
        "Asian": { "Start": "19:00", "End": "00:00" },
        "LondonOpen": { "Start": "02:00", "End": "05:00" },
        "NewYorkOpen": { "Start": "07:00", "End": "10:00" },
        "LondonClose": { "Start": "10:00", "End": "11:00" }
      }
    }
  }
}
